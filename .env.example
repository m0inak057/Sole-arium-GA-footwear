# Application
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
DATABASE_URL=postgresql://gait_user:gait_password@localhost:5432/gait_analysis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# File Storage (MinIO / S3)
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=gait-analysis
S3_REGION=us-east-1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600

# Video Processing
VIDEO_MAX_FILE_SIZE_MB=1000
VIDEO_SUPPORTED_FORMATS=mp4,avi,mov,mkv
VIDEO_MIN_FPS=30
VIDEO_MIN_RESOLUTION_HEIGHT=720

# Paths
DATA_DIR=./data
MODELS_DIR=./models
CONFIGS_DIR=./configs
LOGS_DIR=./logs

# API Security
API_KEY_ENABLED=true
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Session & Patient Management
SESSION_STORAGE_PATH=./data/sessions
PROFILE_OUTPUT_FORMAT=json
PROFILE_SCHEMA_VERSION=v1

# Processing Timeouts (seconds)
INGESTION_TIMEOUT=60
POSE_ESTIMATION_TIMEOUT=120
EVENT_DETECTION_TIMEOUT=30
ANALYSIS_TIMEOUT=60
PROFILE_GENERATION_TIMEOUT=30

# Feature Flags
ENABLE_MULTI_VIEW_TRIANGULATION=false
ENABLE_PRESSURE_MAT_VALIDATION=false
ENABLE_FACE_BLUR=true
ENABLE_AUDIT_LOGGING=true

# Privacy & Compliance
GDPR_ENABLED=true
DPDP_2023_COMPLIANT=true
DATA_RETENTION_DAYS=90
PII_ENCRYPTION_ENABLED=true

# Monitoring & Observability
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
SENTRY_ENABLED=false
SENTRY_DSN=

# Development Only
MOCK_VIDEO_ENABLED=false
SYNTHETIC_DATA_MODE=false
SKIP_CALIBRATION_CHECK=false
